# =============================================================================
# Pet Dogs — Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via asyncpg driver)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://petdogs:petdogs123@postgres:5432/petdogs
POSTGRES_DB=petdogs
POSTGRES_USER=petdogs
POSTGRES_PASSWORD=petdogs123

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Cloudinary — image storage for dog photos
# Swap for AWS S3 + CloudFront when migrating to AWS (see .env.prod.example)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------------------------
# CORS — origins allowed to call the API
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost"]

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
