VITE_API_URL=http://localhost:8000

# Cloudflare Web Analytics beacon token. Leave blank to skip analytics.
# To get the token:
#   1. dash.cloudflare.com → Analytics & Logs → Web Analytics
#   2. Click "Add a site" and enter hispike.in
#   3. Cloudflare returns a JS snippet — copy the token from data-cf-beacon='{"token":"..."}'
#   4. Paste it below (and into Render's environment for production builds)
VITE_CF_BEACON_TOKEN=

# Razorpay hosted Payment Link / Payment Page for the Pet Supplies soft-launch.
# Leave blank to keep the trust badges informational ("payments launching soon").
# When set, the "Pay Securely" button on /pet-supplies opens this link so
# customers can pay via UPI / Visa / Mastercard / RuPay / Net Banking and the
# money settles to your bank — no backend/cart needed yet.
# To create one (no code):
#   1. dashboard.razorpay.com → complete KYC (PAN + bank account)
#   2. Payment Pages → Create Payment Page  (or Payment Links → Create)
#   3. Add a title (e.g. "HiSpike Pet Supplies"), let the customer enter the
#      amount, and enable UPI + Cards + RuPay + Net Banking
#   4. Publish, copy the URL (https://pages.razorpay.com/... or https://rzp.io/l/...)
#   5. Paste it below (and into Render's environment for production builds)
VITE_RAZORPAY_PAYMENT_LINK=
