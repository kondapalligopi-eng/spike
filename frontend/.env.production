# VITE_API_URL is set in Render dashboard after backend deploys
# e.g. https://petdogs-backend-xxxx.onrender.com
VITE_USE_MOCK=false

# VITE_CF_BEACON_TOKEN is set in Render dashboard (NOT here) so the
# token isn't checked into source. Get it from Cloudflare:
#   dash.cloudflare.com → Analytics & Logs → Web Analytics → hispike.in
# Paste it as VITE_CF_BEACON_TOKEN in the Render service environment.
