# =============================================================================
# Pet Dogs — Production Environment Variables
# =============================================================================
# Copy this file to .env.prod and fill in real production values:
#   cp .env.prod.example .env.prod
#
# NEVER commit .env.prod to git. Store it securely (e.g. a password manager
# or GoDaddy's file manager, transferred via scp).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
#
# GoDaddy VPS:  point to the Dockerised postgres container (service name)
#   DATABASE_URL=postgresql+asyncpg://petdogs:<password>@postgres:5432/petdogs
#
# AWS migration: replace with your RDS endpoint — no container needed.
#   DATABASE_URL=postgresql+asyncpg://<user>:<password>@<rds-endpoint>:5432/petdogs
#   Then remove the postgres service from docker-compose.prod.yml entirely.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://petdogs:CHANGE_ME_STRONG_PASSWORD@postgres:5432/petdogs
POSTGRES_DB=petdogs
POSTGRES_USER=petdogs
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# Redis
#
# GoDaddy VPS:  use the Dockerised redis container (service name)
#   REDIS_URL=redis://redis:6379/0
#
# AWS migration: replace with your ElastiCache endpoint.
#   REDIS_URL=redis://<elasticache-endpoint>:6379/0
#   Then remove the redis service from docker-compose.prod.yml entirely.
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Security / JWT
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Image storage
#
# Option A — Cloudinary (works on both GoDaddy and AWS, easiest to start with)
#   Set CLOUDINARY_* vars and keep your storage_service.py using Cloudinary.
#
# Option B — AWS S3 + CloudFront (preferred for full AWS stack)
#   Comment out Cloudinary vars, set AWS_* vars, and update storage_service.py
#   to use boto3. Use CloudFront distribution URL as your CDN prefix.
# -----------------------------------------------------------------------------

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 + CloudFront (uncomment when migrating)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_S3_BUCKET=petdogs-media-prod
# AWS_S3_REGION=us-east-1
# AWS_CLOUDFRONT_URL=https://xxxxxxxxxxxx.cloudfront.net

# -----------------------------------------------------------------------------
# CORS — only your real domain(s) in production
# -----------------------------------------------------------------------------
CORS_ORIGINS=["https://yourpetdogswebsite.com","https://www.yourpetdogswebsite.com"]

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
