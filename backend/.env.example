# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/petdogs

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment
ENVIRONMENT=development

# Bootstrap admin (read by scripts/bootstrap_admin.py on every boot)
# Leave both blank to skip the seed in non-prod environments.
# In prod these are set in the Render dashboard, never committed.
ADMIN_EMAIL=support@hispike.in
ADMIN_PASSWORD=spike
ADMIN_FULL_NAME=HiSpike Support
